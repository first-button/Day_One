# Stage 1: Build
FROM node:20-alpine AS build
WORKDIR /app
COPY firstbutton/package.json firstbutton/package-lock.json* ./
RUN npm install
COPY firstbutton/ .
RUN npm run build

# Stage 2: Serve
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
ARG NGINX_CONF=nginx.conf
COPY ${NGINX_CONF} /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
